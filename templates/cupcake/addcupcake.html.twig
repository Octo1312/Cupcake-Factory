{% extends 'base.html.twig' %}

{% block title %}{{ isModification ? 'Modifier un cupcake' :  'Ajouter un cupcake' }}{% endblock %}

{% block main %}
    <section id="cupcake">
        <div class="container">
                <div class="container-form">
                    <h1> {{ isModification ? 'Modifier le cupcake' :  'Ajouter un cupcake' }}</h1>

                    {{form_start(form)}}
                        <div class="form">
                            {{form_row(form.name, {
                                'label': 'Nom de votre Cupcake'
                            }) }}
                            {{form_row(form.price, {
                                'label': 'Prix de votre Cupcake'
                            }) }}
                            {{form_row(form.description, {
                                'label': 'Description de votre Cupcake'
                            }) }}
                            {{form_row(form.colors, {
                                'label': 'Couleur de votre Cupcake'
                            }) }}
                            {{form_row(form.imageFile, {
                                'label': 'Image de votre Cupcake',
                                'label_attr' : {'class' : 'file'}
                            }) }}
                            <button>{{ isModification ? 'Modifier' :  'Ajouter' }}</button>
                        </div>
                    {{form_end(form)}}
                  </div>
            </div>
    </section>

{% endblock %}